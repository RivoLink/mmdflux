{
  "name": "@mmds/tldraw",
  "version": "0.2.0",
  "type": "module",
  "description": "Convert MMDS JSON to tldraw .tldr format",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "mmds-to-tldraw": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "check": "biome check",
    "fmt": "biome check --write",
    "test": "npm run build && node --test --test-force-exit test/*.test.mjs",
    "prepublishOnly": "npm run build",
    "start": "node dist/cli.js",
    "preview": "vite --config vite.preview.config.ts"
  },
  "dependencies": {
    "@mmds/core": "^0.2.0",
    "@tldraw/editor": "4.4.0",
    "fractional-indexing": "^3.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@types/node": "^25.2.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tldraw": "4.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "keywords": [
    "mmds",
    "tldraw",
    "mmdflux",
    "diagram"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mmdflux/mmdflux.git",
    "directory": "packages/mmds-tldraw"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
