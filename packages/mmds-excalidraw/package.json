{
  "name": "@mmds/excalidraw",
  "version": "0.1.0",
  "type": "module",
  "description": "Convert MMDS JSON to Excalidraw format with polyline edge routing",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "mmds-to-excalidraw": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "check": "biome check",
    "fmt": "biome check --write",
    "test": "npm run build && node --test test/*.test.mjs",
    "prepublishOnly": "npm run build",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "@mmds/core": "^0.1.0"
  },
  "keywords": [
    "mermaid",
    "excalidraw",
    "mmds",
    "mmdflux",
    "diagram",
    "flowchart"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mmdflux/mmdflux.git",
    "directory": "packages/mmds-excalidraw"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@types/node": "^25.2.1",
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}
