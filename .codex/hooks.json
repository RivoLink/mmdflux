{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "./.codex/hooks/start-architecture-watch.sh",
            "timeout": 50
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./.codex/hooks/snapshot-rust-status.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./.codex/hooks/check-architecture-on-stop.sh",
            "timeout": 120,
            "statusMessage": "checking architecture after Rust edits"
          }
        ]
      }
    ]
  }
}
